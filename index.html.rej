+// ── MODERATION ──
+function renderMod(){
+  const pub=db.posts.filter(p=>p.status==='published').length;
+  const draft=db.posts.filter(p=>p.status==='draft').length;
+  const authors=[...new Set(db.posts.map(p=>p.author))];
+  document.getElementById('modPub').textContent=pub;
+  document.getElementById('modDraft').textContent=draft;
+  document.getElementById('modAuthors').textContent=authors.length;
+  document.getElementById('modLbl').textContent='مراجعة وإدارة المحتوى — '+db.posts.length+' مقال';
+  // Populate author filter
+  const authFilt=document.getElementById('modAuthorFilt');
+  if(authFilt){
+    const curVal=authFilt.value;
+    authFilt.innerHTML='<option value="all">كل الكتّاب</option>'+authors.map(a=>`<option value="${a}">${a}</option>`).join('');
+    authFilt.value=curVal||'all';
+  }
+  let posts=[...db.posts];
+  const s=(document.getElementById('modSearch')?.value||'').toLowerCase();
+  const f=document.getElementById('modFilt')?.value||'all';
+  const af=document.getElementById('modAuthorFilt')?.value||'all';
+  if(s)posts=posts.filter(p=>p.title.toLowerCase().includes(s));
+  if(f!=='all')posts=posts.filter(p=>p.status===f);
+  if(af!=='all')posts=posts.filter(p=>p.author===af);
+  const b=document.getElementById('modBody');
+  if(!posts.length){b.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:2rem">لا توجد نتائج</td></tr>';return;}
+  b.innerHTML=posts.map(p=>`<tr><td><strong>${esc(p.title)}</strong></td><td><div style="display:flex;align-items:center;gap:.4rem"><div class="av" style="background:linear-gradient(135deg,var(--accent),var(--accent2));width:22px;height:22px;font-size:.6rem">${p.author[0]}</div>${esc(p.author)}</div></td><td><span class="badge bcat">${esc(p.category)}</span></td><td><span class="badge ${p.status==='published'?'bpub':'bdr'}">${p.status==='published'?'🟢 منشور':'⚪ مسودة'}</span></td><td>${fmtD(p.date)}</td><td><div class="acts">${p.status==='draft'?`<button class="btn btn-teal btn-xs" onclick="approvePost(${p.id})">نشر</button>`:`<button class="btn btn-warn btn-xs" onclick="hidePost(${p.id})">إخفاء</button>`}<button class="btn btn-primary btn-xs" onclick="openEditPost(${p.id})">تعديل</button><button class="btn btn-danger btn-xs" onclick="rmPost(${p.id});renderMod()">حذف</button></div></td></tr>`).join('');
+}
