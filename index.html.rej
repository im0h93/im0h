+// ── EDIT POST ──
+function openEditPost(id){
+  const p=db.posts.find(x=>x.id===id);if(!p)return;
+  editingPostId=id;
+  document.getElementById('editPostTitle').value=p.title;
+  document.getElementById('editPostContent').value=p.content;
+  // Populate categories
+  const sel=document.getElementById('editPostCat');
+  sel.innerHTML=db.categories.map(c=>`<option${c.name===p.category?' selected':''}>${c.name}</option>`).join('');
+  document.getElementById('editPostStatus').value=p.status;
+  document.getElementById('editMov').classList.add('open');
+}
+function closeEditModal(){document.getElementById('editMov').classList.remove('open');editingPostId=null;}
+function saveEditPost(){
+  if(!editingPostId)return;
+  const p=db.posts.find(x=>x.id===editingPostId);if(!p)return;
+  const title=document.getElementById('editPostTitle').value.trim();
+  const content=document.getElementById('editPostContent').value.trim();
+  if(!title||!content){toast('يرجى ملء العنوان والمحتوى','terr');return;}
+  p.title=title;
+  p.content=content;
+  p.category=document.getElementById('editPostCat').value;
+  p.status=document.getElementById('editPostStatus').value;
+  addAct('pub','تم تعديل: "'+title+'"');
+  saveDB();closeEditModal();renderPT();updBadges();
+  toast('تم حفظ التعديلات ✅','tok');
+}
+
+// ── CATEGORIES ──
+function renderCats(){
+  document.getElementById('catLbl').textContent=db.categories.length+' تصنيف';
+  const grid=document.getElementById('catGrid');
+  if(!db.categories.length){grid.innerHTML='<div class="empty" style="grid-column:1/-1"><div class="ei">🏷️</div><h3>لا توجد تصنيفات</h3><p>أضف تصنيفاً جديداً</p></div>';return;}
+  grid.innerHTML=db.categories.map((c,i)=>{
+    const count=db.posts.filter(p=>p.category===c.name).length;
+    return `<div class="cat-card"><div class="cat-emoji" style="border:1px solid ${c.color}30">${c.emoji}</div><div class="cat-info"><div class="cat-name">${esc(c.name)}</div><div class="cat-count">${count} مقال</div></div><div class="cat-actions"><button class="btn btn-primary btn-xs" onclick="openCatEdit(${i})">تعديل</button><button class="btn btn-danger btn-xs" onclick="rmCat(${i})">حذف</button></div></div>`;
+  }).join('');
+}
+function addCategory(){
+  const name=document.getElementById('newCatName').value.trim();
+  const emoji=document.getElementById('newCatEmoji').value.trim()||'📁';
+  const color=document.getElementById('newCatColor').value;
+  if(!name){toast('يرجى إدخال اسم التصنيف','terr');return;}
+  if(db.categories.find(c=>c.name===name)){toast('هذا التصنيف موجود بالفعل','terr');return;}
+  db.categories.push({name,emoji,color});
+  addAct('new','تمت إضافة تصنيف: '+name);
+  saveDB();updBadges();renderCats();
+  document.getElementById('newCatName').value='';
+  document.getElementById('newCatEmoji').value='';
+  toast('تمت إضافة التصنيف ✅','tok');
+}
+function openCatEdit(idx){
+  const c=db.categories[idx];if(!c)return;
+  editingCatIdx=idx;
+  document.getElementById('editCatName').value=c.name;
+  document.getElementById('editCatEmoji').value=c.emoji;
+  document.getElementById('catEditMov').classList.add('open');
+}
+function closeCatEdit(){document.getElementById('catEditMov').classList.remove('open');editingCatIdx=null;}
+function saveCatEdit(){
+  if(editingCatIdx===null)return;
+  const c=db.categories[editingCatIdx];if(!c)return;
+  const oldName=c.name;
+  const newName=document.getElementById('editCatName').value.trim();
+  const newEmoji=document.getElementById('editCatEmoji').value.trim()||'📁';
+  if(!newName){toast('يرجى إدخال اسم التصنيف','terr');return;}
+  // Update posts that use this category
+  if(oldName!==newName){
+    db.posts.forEach(p=>{if(p.category===oldName)p.category=newName;});
+  }
+  c.name=newName;
+  c.emoji=newEmoji;
+  addAct('pub','تم تعديل تصنيف: '+newName);
+  saveDB();closeCatEdit();renderCats();
+  toast('تم تعديل التصنيف ✅','tok');
+}
+function rmCat(idx){
+  const c=db.categories[idx];if(!c)return;
+  const count=db.posts.filter(p=>p.category===c.name).length;
+  if(count>0){toast('لا يمكن حذف تصنيف يحتوي على '+count+' مقال. انقل المقالات أولاً','terr');return;}
+  showDel(()=>{
+    const name=db.categories[idx].name;
+    db.categories.splice(idx,1);
+    addAct('del','حُذف التصنيف: '+name);
+    saveDB();updBadges();renderCats();toast('تم حذف التصنيف','tinf');
+  });
+}
+
+// ── PAGES ──
+function renderPages(){
+  document.getElementById('pageLbl').textContent=db.pages.length+' صفحة';
+  const el=document.getElementById('pagesList');
+  if(!db.pages.length){el.innerHTML='<div class="empty"><div class="ei">📑</div><h3>لا توجد صفحات</h3><p>أنشئ صفحتك الأولى</p></div>';return;}
+  el.innerHTML=db.pages.map(p=>`<div class="page-card"><div class="page-card-header"><div class="page-card-title">${p.showNav?'🔗':''} ${esc(p.title)}</div><div class="acts"><button class="btn btn-primary btn-xs" onclick="openPageEditor(${p.id})">تعديل</button><button class="btn btn-warn btn-xs" onclick="tglPage(${p.id})">${p.status==='published'?'إخفاء':'نشر'}</button><button class="btn btn-danger btn-xs" onclick="rmPage(${p.id})">حذف</button></div></div><div class="page-card-slug">/${esc(p.slug)}</div><div class="page-card-excerpt">${esc(p.content)}</div><div class="page-card-meta"><span><span class="badge ${p.status==='published'?'bpub':'bdr'}">${p.status==='published'?'🟢 منشور':'⚪ مسودة'}</span> ${p.showNav?'<span class="badge badm">في القائمة</span>':''}</span><span>${fmtD(p.date)}</span></div></div>`).join('');
+}
+function openPageEditor(id){
+  if(id){
+    const p=db.pages.find(x=>x.id===id);if(!p)return;
+    editingPageId=id;
+    document.getElementById('pageEdTitle').textContent='✏️ تعديل الصفحة';
+    document.getElementById('pgTitle').value=p.title;
+    document.getElementById('pgSlug').value=p.slug;
+    document.getElementById('pgContent').value=p.content;
+    document.getElementById('pgStatus').value=p.status;
+    document.getElementById('pgShowNav').value=p.showNav?'yes':'no';
+  }else{
+    editingPageId=null;
+    document.getElementById('pageEdTitle').textContent='📑 صفحة جديدة';
+    document.getElementById('pgTitle').value='';
+    document.getElementById('pgSlug').value='';
+    document.getElementById('pgContent').value='';
+    document.getElementById('pgStatus').value='published';
+    document.getElementById('pgShowNav').value='yes';
+  }
+  document.getElementById('pageEdMov').classList.add('open');
+}
+function closePageEditor(){document.getElementById('pageEdMov').classList.remove('open');editingPageId=null;}
+function savePageEditor(){
+  const title=document.getElementById('pgTitle').value.trim();
+  const slug=document.getElementById('pgSlug').value.trim().replace(/\s+/g,'-').toLowerCase();
+  const content=document.getElementById('pgContent').value.trim();
+  const status=document.getElementById('pgStatus').value;
+  const showNav=document.getElementById('pgShowNav').value==='yes';
+  if(!title||!slug||!content){toast('يرجى ملء جميع الحقول','terr');return;}
+  // Check slug uniqueness
+  const existing=db.pages.find(p=>p.slug===slug&&p.id!==editingPageId);
+  if(existing){toast('هذا الرابط مستخدم بالفعل','terr');return;}
+  if(editingPageId){
+    const p=db.pages.find(x=>x.id===editingPageId);if(!p)return;
+    p.title=title;p.slug=slug;p.content=content;p.status=status;p.showNav=showNav;
+    addAct('pub','تم تعديل صفحة: '+title);
+    toast('تم تعديل الصفحة ✅','tok');
+  }else{
+    db.pages.push({id:Date.now(),title,slug,content,status,showNav,date:today()});
+    addAct('new','تمت إضافة صفحة: '+title);
+    toast('تمت إضافة الصفحة ✅','tok');
+  }
+  saveDB();closePageEditor();updBadges();renderPages();
+}
+function tglPage(id){
+  const p=db.pages.find(x=>x.id===id);if(!p)return;
+  p.status=p.status==='published'?'draft':'published';
+  addAct(p.status==='published'?'pub':'new',(p.status==='published'?'نُشرت':'أُخفيت')+' صفحة: "'+p.title+'"');
+  saveDB();renderPages();toast('تم تحديث الحالة','tok');
+}
+function rmPage(id){
+  const p=db.pages.find(x=>x.id===id);
+  showDel(()=>{db.pages=db.pages.filter(x=>x.id!==id);addAct('del','حُذفت صفحة: "'+p?.title+'"');saveDB();updBadges();renderPages();toast('تم الحذف','tinf');});
 }
 
